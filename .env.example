# Copy to .env.local and fill in values from your Supabase project
# (Project Settings → API).
# These are PUBLIC values — safe to expose in the browser. The service
# role key is NEVER set here; it lives only as a secret in the Supabase
# Edge Function environment.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Optional, for running Playwright smoke tests locally:
# E2E_ADMIN_EMAIL=admin@example.com
# E2E_ADMIN_PASSWORD=your-test-admin-password
# E2E_MENTOR_PIN=12345678
# E2E_GROUP_ID=uuid-of-a-test-group
